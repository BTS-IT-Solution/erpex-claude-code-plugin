{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/erpex_agentic_client.py\" hook-user-prompt || python \"${CLAUDE_PLUGIN_ROOT}/scripts/erpex_agentic_client.py\" hook-user-prompt",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/erpex_agentic_client.py\" hook-stop || python \"${CLAUDE_PLUGIN_ROOT}/scripts/erpex_agentic_client.py\" hook-stop",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/erpex_agentic_client.py\" hook-pre-exit-plan || python \"${CLAUDE_PLUGIN_ROOT}/scripts/erpex_agentic_client.py\" hook-pre-exit-plan",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/erpex_agentic_client.py\" hook-post-exit-plan || python \"${CLAUDE_PLUGIN_ROOT}/scripts/erpex_agentic_client.py\" hook-post-exit-plan",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
